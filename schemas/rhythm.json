{    
    "$schema": "https://json-schema.org/draft-07/schema#",
    "title": "Rhythm definition",
    "description": "JSON Schema for rhythm definitions",
    "type": "object",
    "additionalProperties": false,
    "properties": {
        "alternativeNames": {
            "type": "string"
        },
        "category": {
            "type": "string"
        },
        "definition": {
            "$ref": "./rhythm/rhythm.json"
        },
        "name": {
            "type": "string"
        },
        "text": {
            "type": "string"
        },
        "timeSignatureNumerator": {
            "type": "integer"
        },
        "usageText": {
            "type": "string"
        }
    },
    "required": ["alternativeNames", "category", "name", "text", "timeSignatureNumerator", "usageText"]
}