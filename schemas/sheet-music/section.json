{    
    "$schema": "https://json-schema.org/draft-07/schema#",
    "title": "Sheet music section definition",
    "description": "JSON Schema for sheet music section definitions",
    "type": "object",
    "additionalProperties": false,
    "properties": {
        "chordLanguage": {
            "type": "string",
            "enum": ["english", "italian"]
        },
        "events": {
            "type": "array",
            "items": {
                "$ref": "./event.json"
            }
        },
        "melodyLanguage": {
            "type": "string",
            "enum": ["english", "italian"]
        },
        "name": {
            "type": "string"
        }
    },
    "required": ["events", "melodyLanguage", "name"]
}