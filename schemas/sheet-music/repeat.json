{    
    "$schema": "https://json-schema.org/draft-07/schema#",
    "title": "Repeat definition",
    "description": "JSON Schema for repeat definitions",
    "type": "object",
    "additionalProperties": false,
    "properties": {
        "repeat": {
            "oneOf": [
                {
                    "$ref": "./melody.json"
                },
                {
                    "type": "array",
                    "items": {
                        "$ref": "./melody.json"
                    }
                }
            ]
        }
    },
    "required": ["repeat"]
}