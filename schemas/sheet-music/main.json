{    
    "$schema": "https://json-schema.org/draft-07/schema#",
    "title": "Sheet music definition",
    "description": "JSON Schema for sheet music definitions",
    "type": "object",
    "additionalProperties": false,
    "properties": {
        "layout": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "globalStaffSize": {
                    "type": "integer",
                    "minimum": 20,
                    "maximum": 36,
                    "default": 20
                },
                "includeLyrics": {
                    "type": "boolean"
                },
                "useTwoColumnsForLyrics": {
                    "type": "boolean"
                }
            },
            "required": []
        },
        "sections": {
            "type": "array",
            "items": {
                "$ref": "./section.json"
            }
        },
        "sectionsSequence": {
            "type": "array",
            "items": {
                "type": "string"
            }
        }
    },
    "required": ["sections", "sectionsSequence"]
}